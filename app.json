{
  "expo": {
    "name": "CatholicPilgrim",
    "slug": "CatholicPilgrimApp",
    "version": "1.0.0",
    "owner": "catholic-pilgrimage-guide",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "pilgrimapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/bglogo.png",
      "resizeMode": "cover",
      "backgroundColor": "#1a0a00"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.PilgrimApp"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a0a00",
        "foregroundImage": "./assets/images/logo.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.anonymous.PilgrimApp",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "POST_NOTIFICATIONS",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "POST_NOTIFICATIONS"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "@rnmapbox/maps",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo.png",
          "color": "#ffffff"
        }
      ]
    ],
    "experiments": {
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "e4b5e46a-3420-46d1-ac57-d1e6a1652bae"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e4b5e46a-3420-46d1-ac57-d1e6a1652bae"
    }
  }
}
