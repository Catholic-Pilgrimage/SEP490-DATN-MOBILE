{
  "expo": {
    "name": "Catholic Pilgrim",
    "slug": "CatholicPilgrimApp",
    "version": "1.0.0",
    "owner": "catholic-pilgrimage-guide",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "pilgrimapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "cover",
      "backgroundColor": "#cfaa3a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.PilgrimApp",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app needs access to your location for check-ins and showing nearby sites.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "This app needs access to your location for check-ins and showing nearby sites.",
        "NSMicrophoneUsageDescription": "This app needs access to your microphone to record audio for your spiritual journals."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#cfaa3a"
      },
      "splash": {
        "image": "./assets/images/logo.png",
        "resizeMode": "contain",
        "backgroundColor": "#cfaa3a"
      },
      "package": "com.anonymous.PilgrimApp",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "POST_NOTIFICATIONS",
        "RECORD_AUDIO"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsVersion": "11.16.2"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo.png",
          "color": "#ffffff"
        }
      ],
      "expo-localization",
      [
        "expo-image-picker",
        {
          "photosPermission": "Ứng dụng cần cấp quyền truy cập thư viện ảnh để thêm ảnh vào bài viết.",
          "cameraPermission": "Ứng dụng cần cấp quyền truy cập máy ảnh để chụp ảnh và quay video.",
          "microphonePermission": "Ứng dụng cần cấp quyền truy cập micro để quay video."
        }
      ],
      "expo-video"
    ],
    "experiments": {
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "e4b5e46a-3420-46d1-ac57-d1e6a1652bae"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e4b5e46a-3420-46d1-ac57-d1e6a1652bae"
    }
  }
}
